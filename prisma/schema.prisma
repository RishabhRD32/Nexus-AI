// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model for personalization
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  password  String?
  settings  Json?    // User preferences
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  conversations Conversation[]
  memories      Memory[]
  knowledge     Knowledge[]
  trainingData  TrainingData[]
  achievements  Achievement[]
}

// Conversation history
model Conversation {
  id        String   @id @default(cuid())
  title     String?
  mode      String   @default("chat") // chat, voice, vision, code, etc.
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  messages Message[]
  user     User?     @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([createdAt])
}

// Individual messages
model Message {
  id             String   @id @default(cuid())
  role           String   // user, assistant, system
  content        String
  type           String   @default("text") // text, image, audio, video, code, document
  metadata       Json?    // Additional data like image URLs, etc.
  feedback       Int?     // User rating 1-5
  learned        Boolean  @default(false) // Whether this was used for training
  conversationId String
  createdAt      DateTime @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([createdAt])
}

// Long-term memory storage
model Memory {
  id          String   @id @default(cuid())
  key         String   @unique
  content     String
  category    String   @default("general") // preference, fact, context, skill
  importance  Int      @default(1) // 1-10 scale
  accessCount Int      @default(0)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastAccessed DateTime?
  
  user        User?    @relation(fields: [userId], references: [id])
  
  @@index([key])
  @@index([category])
  @@index([userId])
}

// Knowledge base entries - for storing learned information
model Knowledge {
  id          String   @id @default(cuid())
  title       String
  content     String
  source      String?  // URL, file path, or source description
  category    String   @default("general") // code, document, article, note, training
  tags        String?  // Comma-separated tags
  embedding   String?  // Vector embedding (stored as JSON string)
  confidence  Float    @default(0.5) // 0-1 confidence score
  verified    Boolean  @default(false) // User verified
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User?    @relation(fields: [userId], references: [id])
  
  @@index([category])
  @@index([userId])
}

// Training data for AI learning
model TrainingData {
  id          String   @id @default(cuid())
  input       String   // User input/query
  output      String   // Expected response
  context     String?  // Additional context
  source      String   @default("user") // user, web, system
  category    String   @default("general") // conversation, code, knowledge, skill
  quality     Int      @default(3) // 1-5 quality rating
  used        Boolean  @default(false) // Whether used in training
  userId      String?
  createdAt   DateTime @default(now())
  
  user        User?    @relation(fields: [userId], references: [id])
  
  @@index([category])
  @@index([source])
  @@index([userId])
}

// Agent tasks for autonomous execution
model AgentTask {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("pending") // pending, running, completed, failed
  agentType   String   // research, coding, vision, creativity, automation
  input       Json?    // Task input parameters
  output      Json?    // Task output/results
  error       String?
  priority    Int      @default(5) // 1-10, lower is higher priority
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([agentType])
}

// Learning feedback
model Feedback {
  id          String   @id @default(cuid())
  messageId   String?
  rating      Int?     // 1-5 stars
  feedback    String?  // User feedback text
  isPositive  Boolean?
  category    String?  // helpfulness, accuracy, relevance
  createdAt   DateTime @default(now())
  
  @@index([messageId])
}

// User achievements and progress
model Achievement {
  id          String   @id @default(cuid())
  type        String   // first_chat, trained_100, verified_50, etc.
  name        String
  description String?
  earnedAt    DateTime @default(now())
  userId      String
  
  user        User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([type])
}

// Neural network training sessions
model TrainingSession {
  id            String   @id @default(cuid())
  name          String
  status        String   @default("pending") // pending, running, completed, failed
  progress      Float    @default(0) // 0-100
  samplesUsed   Int      @default(0)
  accuracy      Float?   // 0-1
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([status])
}
